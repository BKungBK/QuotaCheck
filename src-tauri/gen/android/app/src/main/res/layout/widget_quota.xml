<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@android:color/black">

    <!-- Header Row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/widget_btn_refresh">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ANTIGRAVITY QUOTA"
                android:textColor="#A1A1AA"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/widget_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Synced --:--"
                android:textColor="#71717A"
                android:textSize="9sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/widget_btn_refresh"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_popup_sync"
            android:tint="#A1A1AA"
            android:contentDescription="Refresh Quota" />
    </RelativeLayout>

    <!-- Pool 1 Row (Claude) -->
    <LinearLayout
        android:id="@+id/pool1_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="8dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/pool1_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Claude Sonnet"
                android:textColor="#F4F4F5"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pool1_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="100%"
                android:textColor="#38BDF8"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <ProgressBar
            android:id="@+id/pool1_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="3dp"
            android:max="100"
            android:progress="100" />
    </LinearLayout>

    <!-- Pool 2 Row (Gemini) -->
    <LinearLayout
        android:id="@+id/pool2_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/pool2_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gemini 1.5 Pro"
                android:textColor="#F4F4F5"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pool2_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="100%"
                android:textColor="#818CF8"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <ProgressBar
            android:id="@+id/pool2_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="3dp"
            android:max="100"
            android:progress="100" />
    </LinearLayout>
</LinearLayout>
